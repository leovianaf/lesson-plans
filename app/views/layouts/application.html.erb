<!DOCTYPE html>
<html>
  <head>
    <title><%= content_for(:title) || "Avaliador Planos" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="Avaliador Planos">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Enable PWA manifest for installable apps (make sure to enable in config/routes.rb too!) %>
    <%#= tag.link rel: "manifest", href: pwa_manifest_path(format: :json) %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%# Includes all stylesheet files in app/assets/stylesheets %>
    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="bg-slate-50 flex h-screen overflow-hidden antialiased text-slate-800">
    <% if authenticated? %>
      <aside id="main-sidebar" class="w-20 bg-[#4C2B9A] flex flex-col items-start py-6 shadow-xl z-10 shrink-0 transition-all duration-300 overflow-hidden">

        <%# Botão Hambúrguer (Abre/Fecha) %>
        <div class="mb-10 w-full px-5">
          <button onclick="toggleSidebar()" class="text-white cursor-pointer hover:bg-white/10 p-2 rounded-lg transition flex items-center justify-center w-10 h-10">
            <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"></path></svg>
          </button>
        </div>

        <nav class="flex flex-col gap-4 w-full px-4 flex-1">

          <%# Math (Calculator) %>
          <%= link_to root_path(discipline: "Matemática"), class: "text-white/70 hover:text-white hover:bg-white/10 p-3 rounded-lg transition flex items-center #{'bg-white/20 text-white' if current_page?(root_path) && (params[:discipline] == 'Matemática' || params[:discipline].blank?)}" do %>
            <svg class="w-6 h-6 shrink-0" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <rect width="16" height="20" x="4" y="2" rx="2"></rect>
              <line x1="8" x2="16" y1="6" y2="6"></line>
              <line x1="16" x2="16" y1="14" y2="18"></line>
              <path d="M16 10h.01"></path>
              <path d="M12 10h.01"></path>
              <path d="M8 10h.01"></path>
              <path d="M12 14h.01"></path>
              <path d="M8 14h.01"></path>
              <path d="M12 18h.01"></path>
              <path d="M8 18h.01"></path>
            </svg>
            <span class="sidebar-text hidden ml-4 font-medium whitespace-nowrap">Matemática</span>
          <% end %>

          <%# Portuguese (Open Book) %>
          <%= link_to root_path(discipline: "Português"), class: "text-white/70 hover:text-white hover:bg-white/10 p-3 rounded-lg transition flex items-center #{'bg-white/20 text-white' if params[:discipline] == 'Português'}" do %>
            <svg class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 0 0 6 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 0 1 6 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 0 1 6-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0 0 18 18a8.967 8.967 0 0 0-6 2.292m0-14.25v14.25" /></svg>
            <span class="sidebar-text hidden ml-4 font-medium whitespace-nowrap">Português</span>
          <% end %>

          <%# History (Checklist) %>
          <%= link_to history_path, class: "text-white/70 hover:text-white hover:bg-white/10 p-3 rounded-lg transition flex items-center #{'bg-white/20 text-white' if current_page?(history_path)}" do %>
            <svg class="w-6 h-6 shrink-0" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" d="M11.35 3.836c-.065.21-.1.433-.1.664 0 .414.336.75.75.75h4.5a.75.75 0 0 0 .75-.75 2.25 2.25 0 0 0-.1-.664m-5.8 0A2.251 2.251 0 0 1 13.5 2.25H15c1.012 0 1.867.668 2.15 1.586m-5.8 0c-.376.023-.75.05-1.124.08C9.095 4.01 8.25 4.973 8.25 6.108V8.25m8.9-4.414c.376.023.75.05 1.124.08 1.131.094 1.976 1.057 1.976 2.192V16.5A2.25 2.25 0 0 1 18 18.75h-2.25m-7.5-10.5H4.875c-.621 0-1.125.504-1.125 1.125v11.25c0 .621.504 1.125 1.125 1.125h9.75c.621 0 1.125-.504 1.125-1.125V18.75m-7.5-10.5h6.375c.621 0 1.125.504 1.125 1.125v9.375m-8.25-3 1.5 1.5 3-3.75" /></svg>
            <span class="sidebar-text hidden ml-4 font-medium whitespace-nowrap">Histórico</span>
          <% end %>
        </nav>

        <%# Sair do Sistema %>
        <div class="w-full px-4 mt-auto">
          <%= button_to session_path, method: :delete, class: "text-white/50 hover:text-red-400 hover:bg-white/10 p-3 rounded-lg flex items-center w-full transition cursor-pointer group", title: "Sair do Sistema" do %>
            <svg class="w-6 h-6 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"></path>
            </svg>
            <span class="sidebar-text hidden ml-4 font-medium whitespace-nowrap group-hover:text-red-400">Sair do Sistema</span>
          <% end %>
        </div>
      </aside>

      <%# Simple script to toggle the sidebar %>
      <script>
          function toggleSidebar() {
              const sidebar = document.getElementById('main-sidebar');
              const texts = document.querySelectorAll('.sidebar-text');

              // Toggles sidebar width
              sidebar.classList.toggle('w-20');
              sidebar.classList.toggle('w-64');

              // Shows/Hides the text in the sidebar
              texts.forEach(text => {
                  text.classList.toggle('hidden');
              });
          }
      </script>
    <% end %>

    <main class="flex-1 overflow-y-auto w-full relative">
      <%= yield %>
    </main>
  </body>
</html>
