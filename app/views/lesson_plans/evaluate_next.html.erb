<div class="max-w-6xl mx-auto py-10 px-8">

  <%# Header %>
  <div class="flex justify-between items-start mb-10">
    <div>
      <h1 class="text-4xl font-extrabold text-slate-900 mb-1"><%= @discipline %></h1>
      <p class="text-slate-600">Avalie planos de aula da disciplina</p>
    </div>

    <div class="flex items-center gap-6">
      <% if @lesson_plan %>
        <a href="<%= @lesson_plan.url %>" target="_blank" class="bg-[#6B46C1] hover:bg-[#553c9a] text-white px-5 py-2.5 rounded-lg font-semibold shadow-sm transition">
          Ver no Nova Escola
        </a>
      <% end %>

      <div class="bg-white p-4 rounded-xl shadow-sm border border-slate-200 min-w-[250px]">
        <div class="text-xs font-bold text-slate-500 mb-2">Planos Avaliados / Total de Planos</div>
        <div class="w-full bg-slate-200 rounded-full h-2.5 mb-2">
          <% percentage = @total_plans > 0 ? (@evaluated_count.to_f / @total_plans * 100) : 0 %>
          <div class="bg-[#6B46C1] h-2.5 rounded-full" style="width: <%= percentage %>%"></div>
        </div>
        <div class="flex justify-between text-sm font-bold text-slate-800">
          <span><%= @evaluated_count %></span>
          <span class="text-slate-400"><%= @total_plans %></span>
        </div>
      </div>
    </div>
  </div>

  <% if @lesson_plan.nil? %>
    <div class="bg-white shadow-sm rounded-xl p-16 text-center border border-slate-200">
      <h2 class="text-3xl font-bold text-[#6B46C1] mb-2">Trabalho Concluído!</h2>
      <p class="text-slate-600 text-lg">Todos os planos de <%= @discipline %> já foram avaliados.</p>
    </div>

  <% else %>
    <%# Lesson Plan Details %>
    <div class="bg-white shadow-sm rounded-2xl p-8 mb-8 border border-slate-100">
      <h2 class="text-xl font-bold text-slate-900 mb-6">Título: <%= @lesson_plan.title %></h2>

      <div class="flex flex-wrap gap-4 mb-6">
        <div class="bg-slate-50 p-4 rounded-xl border border-slate-100 min-w-[180px] shadow-sm">
          <p class="text-xs font-bold text-[#6B46C1] mb-1">Tema</p>
          <p class="text-slate-800 font-semibold"><%= @lesson_plan.theme %></p>
        </div>
        <div class="bg-slate-50 p-4 rounded-xl border border-slate-100 min-w-[120px] shadow-sm">
          <p class="text-xs font-bold text-[#6B46C1] mb-1">Série</p>
          <p class="text-slate-800 font-semibold"><%= @lesson_plan.grade %></p>
        </div>
        <div class="bg-slate-50 p-4 rounded-xl border border-slate-100 min-w-[120px] shadow-sm">
          <p class="text-xs font-bold text-[#6B46C1] mb-1">Duração</p>
          <p class="text-slate-800 font-semibold"><%= @lesson_plan.duration %></p>
        </div>
        <div class="bg-slate-50 p-4 rounded-xl border border-slate-100 min-w-[180px] shadow-sm">
          <p class="text-xs font-bold text-[#6B46C1] mb-1">Habilidades BNCC</p>
          <p class="text-slate-800 font-semibold"><%= @lesson_plan.bncc_skills %></p>
        </div>
      </div>

      <div class="bg-slate-50 p-5 rounded-xl border border-slate-100 mb-6 shadow-sm">
        <p class="text-xs font-bold text-[#6B46C1] mb-2">Objetivos</p>
        <p class="text-slate-800 font-semibold"><%= @lesson_plan.objectives %></p>
      </div>

      <div class="bg-slate-50 p-6 rounded-xl border border-slate-100 shadow-sm">
        <p class="text-xs font-bold text-[#6B46C1] mb-3">Etapas</p>
        <div class="text-slate-800 font-medium whitespace-pre-line leading-relaxed">
          <%= @lesson_plan.steps %>
        </div>
      </div>
    </div>

    <%# Evaluation Area %>
    <div class="bg-[#EBEBEB] p-8 rounded-2xl shadow-inner">
      <h3 class="text-lg font-bold text-slate-900 mb-6">Selecione a melhor avaliação para o plano acima</h3>

      <%= form_with url: save_evaluation_path(@lesson_plan), method: :patch, class: "" do |f| %>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
          <% @evaluations.each_with_index do |evaluation, index| %>
            <label class="relative flex cursor-pointer rounded-xl bg-white p-6 shadow-sm hover:shadow-md transition-all border-2 border-transparent has-[:checked]:border-[#6B46C1] has-[:checked]:ring-2 has-[:checked]:ring-[#6B46C1]/20">
              <%= f.radio_button :chosen_llm_evaluation_id, evaluation.id, class: "peer sr-only", required: true %>
              <div class="flex flex-col w-full">
                <span class="block text-xs font-bold text-slate-500 mb-4">LLM <%= ("A".."Z").to_a[index] %></span>
                <div class="flex items-baseline gap-3">
                  <span class="text-2xl font-extrabold text-[#6B46C1]">Nota:</span>
                  <span class="text-4xl font-extrabold text-[#6B46C1]"><%= evaluation.score %> / 10</span>
                </div>
              </div>
            </label>
          <% end %>
        </div>

        <div class="bg-white p-6 rounded-xl shadow-sm border border-slate-200 mb-6">
          <%= f.label :observation, "Observação (opcional)", class: "block text-xs font-bold text-slate-900 mb-2" %>
          <%= f.text_area :observation, rows: 2, class: "resize-none block w-full rounded-lg border-slate-300 shadow-sm focus:border-[#6B46C1] focus:ring-[#6B46C1] sm:text-sm p-4 border", placeholder: "Alguma observação sobre a nota da LLM ou plano..." %>
        </div>

        <div class="flex justify-end">
          <%= f.submit "Salvar e Ir para o próximo", class: "bg-[#6B46C1] hover:bg-[#553c9a] text-white px-6 py-3 rounded-lg font-semibold shadow-md transition cursor-pointer" %>
        </div>
      <% end %>
    </div>
  <% end %>
</div>
